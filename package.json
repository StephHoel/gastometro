{
    "name": "gastometro",
    "main": "expo-router/entry",
    "version": "1.4.3",
    "scripts": {
        "new-version": "sh ./scripts/add-new-version.sh",
        "release:upload": "sh ./scripts/release-upload.sh",
        "build:local": "sh ./scripts/build-local.sh",
        "clear:modules": "sh ./scripts/clear-node_modules.sh",
        "build:android:local": "cd android/ && gradlew.bat build && gradlew.bat assembleRelease && cd ..",
        "prebuild": "expo prebuild",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "start": "expo start --dev-client",
        "build:android": "eas build -p android --profile preview",
        "build:local:eas": "eas build --platform android --local",
        "web": "expo start --web --dev-client --clear",
        "deps:check": "npx expo-doctor",
        "deps:audit": "npm audit --omit=dev"
    },
    "dependencies": {
        "@expo-google-fonts/inter": "^0.3.0",
        "@expo/vector-icons": "^15.0.2",
        "@react-native-async-storage/async-storage": "2.2.0",
        "@react-navigation/native": "^7.0.14",
        "expo": "56.0.4",
        "expo-clipboard": "~56.0.3",
        "expo-font": "~56.0.5",
        "expo-linking": "~56.0.11",
        "expo-router": "~56.2.6",
        "expo-splash-screen": "~56.0.10",
        "expo-status-bar": "~56.0.4",
        "expo-system-ui": "~56.0.5",
        "expo-web-browser": "~56.0.5",
        "nativewind": "^4.1.23",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-native": "0.85.3",
        "react-native-gesture-handler": "^2.25.0",
        "react-native-reanimated": "4.3.1",
        "react-native-safe-area-context": "~5.7.0",
        "react-native-screens": "4.25.2",
        "react-native-uuid": "^2.0.3",
        "react-native-web": "^0.21.2",
        "tailwindcss": "^3.4.17",
        "zustand": "^5.0.3"
    },
    "devDependencies": {
        "@babel/core": "^7.25.2",
        "@types/react": "~19.2.14",
        "typescript": "~6.0.3"
    },
    "private": true,
    "engines": {
        "node": ">=20 <21",
        "npm": ">=10 <11"
    },
    "packageManager": "npm@10.0.0"
}