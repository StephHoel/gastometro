{
  "name": "gastometro",
  "main": "expo-router/entry",
  "version": "1.5.1",
  "homepage": "https://stephhoel.github.io/gastometro/",
  "scripts": {
    "verify:version-bump": "sh ./scripts/verify-version-bump.sh",
    "new-version": "sh ./scripts/add-new-version.sh",
    "release:upload": "sh ./scripts/release-upload.sh",
    "build:local": "sh ./scripts/build-local.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:csv": "sh ./scripts/test-coverage-csv.sh",
    "clear:coverage": "rm -rf coverage",
    "clear:branches": "sh ./scripts/clear-branches.sh",
    "clear:modules": "sh ./scripts/clear-node_modules.sh",
    "clear": "sh ./scripts/clear.sh",
    "prebuild": "expo prebuild",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start --dev-client",
    "build:android": "eas build -p android --profile production",
    "build:local:eas": "eas build --platform android --local",
    "web": "expo start --web --dev-client --clear",
    "web:build": "expo export --platform web --clear",
    "web:serve": "npx http-server dist -p 3000 -c-1",
    "check:ts": "npx tsc --noEmit",
    "check:biome": "npx biome check .",
    "deps:check": "npx expo-doctor",
    "deps:audit": "npm audit --omit=dev"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.11",
    "expo-build-properties": "~56.0.18",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.16",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.10",
    "expo-splash-screen": "~56.0.10",
    "nativewind": "^4.2.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-uuid": "^2.0.4",
    "react-native-web": "~0.21.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^56.0.12",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "^19.2.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "expo": {
    "autolinking": {
      "android": {
        "exclude": [
          "react-native-reanimated",
          "react-native-worklets",
          "react-native-css-interop"
        ]
      }
    }
  },
  "private": true,
  "allowScripts": {
    "msgpackr-extract@3.0.4": true
  }
}