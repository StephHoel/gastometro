{
  "name": "gastometro",
  "main": "expo-router/entry",
  "version": "1.4.7",
  "scripts": {
    "new-version": "sh ./scripts/add-new-version.sh",
    "verify:version-bump": "sh ./scripts/verify-version-bump.sh",
    "release:upload": "sh ./scripts/release-upload.sh",
    "build:local": "sh ./scripts/build-local.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:csv": "sh ./scripts/test-coverage-csv.sh",
    "clear:coverage": "rm -rf coverage",
    "clear:branches": "sh ./scripts/clear-branches.sh",
    "clear:modules": "sh ./scripts/clear-node_modules.sh",
    "clear": "sh ./scripts/clear.sh",
    "build:android:local": "cd android/ && gradlew.bat build && gradlew.bat assembleRelease && cd ..",
    "prebuild": "expo prebuild",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start --dev-client",
    "build:android": "eas build -p android --profile preview",
    "build:local:eas": "eas build --platform android --local",
    "web": "expo start --web --dev-client --clear",
    "deps:check": "npx expo-doctor",
    "deps:audit": "npm audit --omit=dev"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/ui": "~56.0.15",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.8",
    "expo-clipboard": "^56.0.3",
    "expo-constants": "~56.0.15",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.9",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.8",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "nativewind": "^4.2.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-uuid": "^2.0.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^56.0.12",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.4",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react-test-renderer": "^19.2.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "private": true,
  "allowScripts": {
    "msgpackr-extract@3.0.4": true
  }
}